# Copy this file to .env (same folder). Vite only exposes vars to client
# code when they're prefixed VITE_.

# Backend REST API base URL.
VITE_API_URL=http://localhost:5000/api

# Optional — only needed if the Socket.io server ever lives at a different
# origin than VITE_API_URL (minus the /api suffix). Usually leave unset.
# VITE_SOCKET_URL=http://localhost:5000
