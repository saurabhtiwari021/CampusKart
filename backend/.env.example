# Copy this file to .env and fill in real values. Never commit .env itself.

PORT=5000

# MongoDB Atlas connection string (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campuskart?retryWrites=true&w=majority

# Long random string — e.g. generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated list of origins allowed to call this API.
# The static frontend server in this project runs on :8000 by default.
FRONTEND_URL=http://localhost:8000

# Comma-separated list of email domains allowed to sign up / log in.
# Only @kiit.ac.in is allowed right now — add more later as needed.
ALLOWED_EMAIL_DOMAINS=kiit.ac.in

# Cloudinary (Dashboard > Account Details — free tier is plenty for this project)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
